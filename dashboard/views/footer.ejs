<footer class="modern-footer">
  <div class="footer-container">
    <div class="footer-top">
      <!-- Bot Logo -->
      <div class="footer-logo-section">
        <div class="footer-logo-wrapper">
          <img src="<%= botClient.user.displayAvatarURL({ size: 256 }) %>" alt="<%= botClient.user.username %>" class="footer-logo">
          <div class="footer-status-indicator status-online"></div>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-links">
        <h4><i class="fas fa-link"></i> Links Rápidos</h4>
        <nav class="footer-nav">
          <a href="/" class="footer-link">
            <i class="fas fa-home"></i>
            <span>Início</span>
          </a>
          <a href="/commands" class="footer-link">
            <i class="fas fa-terminal"></i>
            <span>Comandos</span>
          </a>
          <a href="/dashboard" class="footer-link">
            <i class="fas fa-tachometer-alt"></i>
            <span>Dashboard</span>
          </a>
          <a href="/queuedashboard" class="footer-link">
            <i class="fas fa-music"></i>
            <span>Fila</span>
          </a>
        </nav>
      </div>

      <!-- Legal -->
      <div class="footer-legal">
        <h4><i class="fas fa-gavel"></i> Legal</h4>
        <nav class="footer-nav">
          <a href="/termos" class="footer-link">
            <i class="fas fa-file-contract"></i>
            <span>Termos de Serviço</span>
          </a>
          <a href="/privacidade" class="footer-link">
            <i class="fas fa-shield-alt"></i>
            <span>Política de Privacidade</span>
          </a>
        </nav>
      </div>

      <!-- Community -->
      <div class="footer-social">
        <h4><i class="fas fa-share-alt"></i> Comunidade</h4>
        <nav class="footer-nav">
          <a href="https://discord.gg/" target="_blank" rel="noopener noreferrer" class="footer-link">
            <i class="fab fa-discord"></i>
            <span>Support</span>
          </a>
          <a href="https://github.com/Programador-jr/King" target="_blank" rel="noopener noreferrer" class="footer-link">
            <i class="fab fa-github"></i>
            <span>GitHub</span>
          </a>
        </nav>
      </div>

      <!-- Donation -->
      <div class="footer-donation">
        <h4><i class="fas fa-heart"></i> Apoie o Projeto</h4>
        <nav class="footer-nav">
          <a href="https://www.paypal.com/donate/?hosted_button_id=5DDQ8X8YAH5A8" target="_blank" rel="noopener noreferrer" class="footer-link">
            <i class="fab fa-paypal"></i>
            <span>Fazer uma Doação</span>
          </a>
        </nav>
      </div>
    </div>

    <!-- Copyright -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        <p>
          <i class="far fa-copyright"></i>
          <strong><%= new Date().getFullYear() %> <%= botClient.user.username %></strong>
          <span>• Todos os direitos reservados</span>
        </p>
      </div>
    </div>
  </div>
</footer>
