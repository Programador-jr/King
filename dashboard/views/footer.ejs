<section class="site-footer-section">
  <div class="card-footer">
    <hr>
    <div class="footer-content">
      <div class="footer-brand">
        <img src="<%= botClient.user.displayAvatarURL({ size: 256 }) %>" alt="<%= botClient.user.username %>" style="width: 38px; border-radius: 50%; margin-right: 8px; vertical-align: middle;">
        <span><%= botClient.user.username %> | Experiência Completa para Servidores</span>
      </div>
      
      <div class="footer-links">
        <a href="/termos">Termos de Serviço</a>
        <span class="footer-divider">|</span>
        <a href="/privacidade">Política de Privacidade</a>
      </div>
      
      <div class="footer-social">
        <a href="https://discord.gg/" target="_blank" rel="noopener noreferrer" aria-label="Discord Support">
          <i class="fab fa-discord"></i>
        </a>
        <a href="https://github.com/Programador-jr/King" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <i class="fab fa-github"></i>
        </a>
      </div>
    </div>
    
    <h5>
      <small style="color:#7ea7c0;">&copy; <%= new Date().getFullYear() %> KING. Todos os direitos reservados.</small>
    </h5>
  </div>
</section>
