<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="<%= bot.avatar %>">
    <link rel="stylesheet" href="/public/style.css">
    <link rel="stylesheet" href="/public/alerts.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-BmbxuPwQa2lc/FVzBcNJ7UAyJxM6wuqIj61tLrc4wSX0szH/Ev+nYRRuWlolflfl" crossorigin="anonymous">
    <link rel="stylesheet" href="/index.css">
    <title>Ticket #<%= ticket.ticketNumber %> | <%= guild.name %></title>
  </head>
  <body>
    <%- include('header'); -%>

    <section class="dashboard-page settings-page">
      <div class="form-holder">
        <div class="form-content">
          <div class="form-items">
            <div class="settings-header">
              <h3>🎫 Ticket #<%= ticket.ticketNumber %></h3>
              <p>Detalhes do ticket de <b><%= guild.name %></b></p>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="card bg-dark text-white mb-3">
                  <div class="card-header">Informações do Ticket</div>
                  <div class="card-body">
                    <p><strong>Status:</strong> 
                      <% if (ticket.status === 'open') { %>
                        <span class="badge bg-success">Aberto</span>
                      <% } else { %>
                        <span class="badge bg-danger">Fechado</span>
                      <% } %>
                    </p>
                    <p><strong>Usuário:</strong> <%= ticket.userId %></p>
                    <p><strong>Motivo:</strong> <%= ticket.reason %></p>
                    <p><strong>Criado em:</strong> <%= new Date(ticket.createdAt).toLocaleString('pt-BR') %></p>
                    <% if (ticket.closedAt) { %>
                      <p><strong>Fechado em:</strong> <%= new Date(ticket.closedAt).toLocaleString('pt-BR') %></p>
                      <% const duration = ticket.closedAt - ticket.createdAt; %>
                      <% const minutes = Math.floor(duration / 60000); %>
                      <p><strong>Duração:</strong> <%= minutes %> minutos</p>
                    <% } %>
                    <% if (ticket.closedBy) { %>
                      <p><strong>Fechado por:</strong> <%= ticket.closedBy %></p>
                    <% } %>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="card bg-dark text-white mb-3">
                  <div class="card-header">Ações</div>
                  <div class="card-body">
                    <% if (ticket.channelId) { %>
                      <a href="#" class="btn btn-primary mb-2">Ir para o canal do ticket</a>
                    <% } %>
                    
                    <% if (ticket.status === 'open') { %>
                      <button class="btn btn-danger mb-2" onclick="closeTicket()">Fechar Ticket</button>
                    <% } else { %>
                      <button class="btn btn-success mb-2" onclick="reopenTicket()">Reabrir Ticket</button>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-3">
              <a href="/dashboard/<%= guild.id %>/tickets" class="btn btn-secondary">← Voltar aos Tickets</a>
            </div>

          </div>
        </div>
      </div>
    </section>

    <%- include('footer'); -%>
    <script src="/public/alerts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      async function closeTicket() {
        showConfirm(
          'Fechar Ticket',
          'Tem certeza que deseja fechar este ticket?',
          async () => {
            try {
              const response = await fetch('/api/tickets/<%= guild.id %>/<%= ticket.ticketNumber %>/close', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin'
              });

              const data = await response.json();
              
              if (data.ok) {
                showSuccess('Ticket Fechado', 'O ticket foi fechado com sucesso.');
                setTimeout(() => {
                  window.location.reload();
                }, 1500);
              } else {
                showError('Erro ao Fechar', data.message || 'Não foi possível fechar o ticket.');
              }
            } catch (err) {
              showError('Erro de Conexão', 'Não foi possível conectar ao servidor.');
            }
          },
          null,
          'warning'
        );
      }

      async function reopenTicket() {
        try {
          const response = await fetch('/api/tickets/<%= guild.id %>/<%= ticket.ticketNumber %>/reopen', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin'
          });

          const data = await response.json();
          
          if (data.ok) {
            showSuccess('Ticket Reaberto', 'O ticket foi reaberto com sucesso.');
            setTimeout(() => {
              window.location.reload();
            }, 1500);
          } else {
            showError('Erro ao Reabrir', data.message || 'Não foi possível reabrir o ticket.');
          }
        } catch (err) {
          showError('Erro de Conexão', 'Não foi possível conectar ao servidor.');
        }
      }
    </script>
  </body>
</html>
